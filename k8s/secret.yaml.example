# ──────────────────────────────────────────────────────────────────────────────
# ARCHIVO DE REFERENCIA — NO COMMITEAR CON VALORES REALES
# ──────────────────────────────────────────────────────────────────────────────
# Este archivo es un template. En producción, crear el Secret con:
#
#   kubectl create secret generic tramites-omr-secrets \
#     --namespace tramites-omr \
#     --from-literal=APP_KEY='base64:...' \
#     --from-literal=JWT_SECRET='...' \
#     --from-literal=DB_USERNAME='...' \
#     --from-literal=DB_PASSWORD='...' \
#     --from-literal=GEMINI_API_KEY='...'
#
# O gestionarlo con Workload Identity + Secret Manager de GCP:
#   https://cloud.google.com/secret-manager/docs/secret-manager-managed-binauthz
# ──────────────────────────────────────────────────────────────────────────────

apiVersion: v1
kind: Secret
metadata:
  name: tramites-omr-secrets
  namespace: tramites-omr
  labels:
    app.kubernetes.io/name: tramites-omr
type: Opaque
stringData:
  # Generar con: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
  APP_KEY: "base64:REEMPLAZAR_CON_32_BYTES_EN_BASE64="

  # Generar con: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
  JWT_SECRET: "REEMPLAZAR_CON_64_CARACTERES_HEX"

  # Credenciales de la base de datos (Cloud SQL o externo)
  DB_USERNAME: "REEMPLAZAR"
  DB_PASSWORD: "REEMPLAZAR"

  # API key de Google Gemini (opcional — si está vacío, /resumen-ia devuelve 503)
  GEMINI_API_KEY: ""
