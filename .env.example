# ── Trámites OMR — Variables de entorno para Docker Compose ──────────────────
# Copia este archivo a .env y rellena los valores:
#
#   cp .env.example .env
#
# Las claves de abajo son valores demo para desarrollo local (SQLite con datos de prueba).
# Cambia estos valores si despliegas en produccion.

# ── API ───────────────────────────────────────────────────────────────────────
API_APP_KEY=base64:NhqyibZPesrAv554veB+no+mUkrWF+FRutQjEXADLOk=
API_JWT_SECRET=35cc9a77ca64ee4f125026016fa0bb0da187ead4078c2afd15d961bf33c3fcd9
API_GEMINI_API_KEY=

# Puerto donde escucha la API en tu máquina
API_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL que el NAVEGADOR usa para llamar a la API.
# En Docker local: http://localhost:<API_PORT>/api
VITE_API_URL=http://localhost:8000/api

# Puerto donde sirve el frontend en tu máquina
APP_PORT=80

# ── PostgreSQL (solo si activas el servicio postgres en docker-compose.yml) ───
# POSTGRES_PASSWORD=omr_secret
