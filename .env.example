# ── Trámites OMR — Variables de entorno para Docker Compose ──────────────────
# Copia este archivo a .env y rellena los valores:
#
#   cp .env.example .env
#
# Genera API_APP_KEY con:  php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
# Genera API_JWT_SECRET con: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"

# ── API ───────────────────────────────────────────────────────────────────────
API_APP_KEY=base64:REEMPLAZA_CON_32_BYTES_EN_BASE64=
API_JWT_SECRET=REEMPLAZA_CON_64_CARACTERES_HEX
API_GEMINI_API_KEY=

# Puerto donde escucha la API en tu máquina
API_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL que el NAVEGADOR usa para llamar a la API.
# En Docker local: http://localhost:<API_PORT>/api
VITE_API_URL=http://localhost:8000/api

# Puerto donde sirve el frontend en tu máquina
APP_PORT=80

# ── PostgreSQL (solo si activas el servicio postgres en docker-compose.yml) ───
# POSTGRES_PASSWORD=omr_secret
